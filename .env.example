# =============================================================================
# Camp Intelligence - Environment Variables
# Copy this file to .env and fill in your values
# =============================================================================

# ----------------------------------------------------------------
# REQUIRED: Application Identity
# ----------------------------------------------------------------
# A unique ID for this app instance (can be any string, used in JWTs)
VITE_APP_ID=camp-intelligence-local

# ----------------------------------------------------------------
# REQUIRED: Session Security
# Generate with: openssl rand -hex 32
# ----------------------------------------------------------------
JWT_SECRET=replace_with_a_long_random_secret_string_min_32_chars

# ----------------------------------------------------------------
# REQUIRED: MySQL Database
# Format: mysql://user:password@host:port/dbname
# ----------------------------------------------------------------
DATABASE_URL=mysql://campuser:yourpassword@127.0.0.1:3306/campintelligence

# ----------------------------------------------------------------
# REQUIRED: LLM API (for AI chat features)
# Option A - OpenAI:
#   LLM_API_URL=https://api.openai.com
#   BUILT_IN_FORGE_API_KEY=sk-...
# Option B - Local Ollama (no key needed):
#   LLM_API_URL=http://127.0.0.1:11434
#   LLM_MODEL=llama3
# Option C - Any OpenAI-compatible proxy:
#   BUILT_IN_FORGE_API_URL=https://your-proxy.example.com
# ----------------------------------------------------------------
BUILT_IN_FORGE_API_URL=https://api.openai.com
BUILT_IN_FORGE_API_KEY=sk-your-openai-api-key-here
LLM_MODEL=gpt-4o-mini

# ----------------------------------------------------------------
# OPTIONAL: OAuth Authentication Server
# Required only if using Manus OAuth or a compatible OAuth server.
# For local-only testing with a single admin user, this can be left blank
# and you can create users directly in the DB.
# ----------------------------------------------------------------
OAUTH_SERVER_URL=

# ----------------------------------------------------------------
# OPTIONAL: Owner/Admin User
# Set this to the openId of the user who should have admin role.
# After first login, this user will be automatically elevated to admin.
# ----------------------------------------------------------------
OWNER_OPEN_ID=

# ----------------------------------------------------------------
# OPTIONAL: Redis (required for BullMQ background jobs)
# If not set, background job features (prediction snapshots, etc.) won't run.
# ----------------------------------------------------------------
REDIS_URL=redis://127.0.0.1:6379

# ----------------------------------------------------------------
# Server Port (default: 3000)
# ----------------------------------------------------------------
PORT=3000

# NODE_ENV: set to 'production' for production builds
NODE_ENV=development
